# Endpoints
NETBIRD_MGMT_API_ENDPOINT=https://example.org
NETBIRD_MGMT_GRPC_API_ENDPOINT=https://example.org

# OIDC - using embedded IdP
AUTH_AUDIENCE=<zitdel/keycloak client_id>
AUTH_CLIENT_ID=<zitdel/keycloak client_id>
AUTH_CLIENT_SECRET=
AUTH_AUTHORITY=https://example.org/oauth2
USE_AUTH0=false
AUTH_SUPPORTED_SCOPES=openid profile email groups
AUTH_REDIRECT_URI=/nb-auth
AUTH_SILENT_REDIRECT_URI=/nb-silent-auth

# SSL - disabled when behind reverse proxy (Traefik handles TLS)
NGINX_SSL_PORT=80
LETSENCRYPT_DOMAIN=none