# Endpoints for the dashboard to communicate with the server [cite: 115]
# Must be reachable from the user's browser [cite: 116]
NETBIRD_MGMT_API_ENDPOINT=https://netbird.example.com
NETBIRD_MGMT_GRPC_API_ENDPOINT=https://netbird.example.com

# OIDC configuration for the embedded IdP [cite: 120, 121]
AUTH_AUDIENCE=netbird-dashboard
AUTH_CLIENT_ID=netbird-dashboard
AUTH_CLIENT_SECRET=
AUTH_AUTHORITY=https://netbird.example.com/oauth2 [cite: 124]
USE_AUTH0=false [cite: 126]
AUTH_SUPPORTED_SCOPES=openid profile email groups [cite: 127]

# Redirect paths after login [cite: 128, 130]
AUTH_REDIRECT_URI=/nb-auth
AUTH_SILENT_REDIRECT_URI=/nb-silent-auth

# SSL Configuration [cite: 133, 135]
# Set to 'none' because Traefik handles TLS termination 
LETSENCRYPT_DOMAIN=none
NGINX_SSL_PORT=443